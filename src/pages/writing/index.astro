---
import Base from '../../layouts/Base.astro';
import Prompt from '../../components/Prompt.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const fmt = (d: Date) => new Date(d).toISOString().slice(0, 10);
---

<Base
  title="Writing — Barnaby Napier"
  section="writing"
  description="Essays on risk, probability, fiction, and building things."
>
  <Prompt cmd="writing/" />
  <div class="section" style="margin-top:1.2rem">
    {
      posts.map((post) => (
        <a class="entry" href={`/writing/${post.id}/`}>
          <span class="date">{fmt(post.data.date)}</span>
          <span class="title">{post.data.title}</span>
          <span class="tags">
            {post.data.tags.map((t) => `#${t}`).join(' ')}
          </span>
        </a>
      ))
    }
  </div>
</Base>
